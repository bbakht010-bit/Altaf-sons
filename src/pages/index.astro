---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { hero, otherPartners, projects, services, site, stats, unPartners, whyChoose } from "../data/site";
---

<BaseLayout
  title="Home"
  description="Altaf & Sons is a Jhang Saddar-based general order supplier and humanitarian aid procurement company for relief items, textiles, stationery, and general supplies."
>
  <section class="hero-section full-screen">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p>{hero.body}</p>
        <div class="hero-actions">
          <a class="button primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
          <a class="button secondary" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
        </div>
      </div>

      <div class="hero-card" aria-label="Company capability summary">
        <div class="hero-card-top">
          <img class="hero-logo" src={site.logoSrc} alt={`${site.name} logo`} />
          <strong>General Order Suppliers</strong>
        </div>
        <ul>
          <li>Humanitarian aid and relief item procurement</li>
          <li>Textiles, stationery, and general order supplies</li>
          <li>Timely delivery for institutional project teams</li>
        </ul>
        <div class="trust-strip">
          <span>Procurement</span>
          <span>Sourcing</span>
          <span>Delivery</span>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-bar" aria-label="Trusted by partner organizations">
    <div class="container trust-inner">
      <p>Trusted support for relief, development, and institutional procurement.</p>
      <div class="keyword-strip">
        <span>UN agencies</span>
        <span>NGOs</span>
        <span>Government</span>
        <span>Relief supply</span>
      </div>
    </div>
  </section>

  <section class="stats-section">
    <div class="container stats-grid">
      {
        stats.map((stat) => (
          <div class="stat-card">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <SectionHeading
        eyebrow="About us"
        title="Reliable procurement and timely delivery from Jhang Saddar, Punjab."
        body={`${site.name} is a procurement and supply company specializing in humanitarian aid, relief items, textiles, stationery, and general order supplies for NGOs, international firms, government agencies, and institutional clients.`}
      />
      <div class="keyword-panel">
        <span>Procurement</span>
        <span>Sourcing</span>
        <span>Relief items</span>
        <span>Textiles</span>
        <span>Stationery</span>
        <span>General supplies</span>
        <span>Timely delivery</span>
        <span>Pakistan-wide support</span>
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="container">
      <SectionHeading
        eyebrow="Our expertise"
        title="Supplies for humanitarian, government, and institutional needs."
        body="Clear categories help clients quickly understand what Altaf & Sons can source and deliver."
      />
      <div class="card-grid two-column">
        {services.map((service) => <ServiceCard {...service} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Esteemed partners and clients"
        title="Clear partner display, grouped for quick trust."
        body="UN-affiliated agencies are separated from other humanitarian, disaster management, and institutional partners."
      />
      <div class="partner-groups">
        <section class="partner-group-card">
          <p class="eyebrow">UN-affiliated</p>
          <div class="mini-logo-grid">
            {
              unPartners.map((partner) => (
                <article class="logo-card with-logo compact-logo-card">
                  <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} />
                  <h3>{partner.name}</h3>
                  <div class="tag-row">{partner.keywords.map((keyword) => <span>{keyword}</span>)}</div>
                </article>
              ))
            }
          </div>
        </section>
        <section class="partner-group-card">
          <p class="eyebrow">Humanitarian / government</p>
          <div class="mini-logo-grid">
            {
              otherPartners.map((partner) => (
                <article class={`logo-card compact-logo-card${partner.logoSrc ? " with-logo" : ""}`}>
                  {partner.logoSrc ? <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} /> : <span class="logo-mark">{partner.shortName}</span>}
                  <h3>{partner.name}</h3>
                  <div class="tag-row">{partner.keywords.map((keyword) => <span>{keyword}</span>)}</div>
                </article>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="container">
      <SectionHeading
        eyebrow="Why choose Altaf & Sons"
        title="Professional supply support for projects where timing matters."
      />
      <div class="why-grid">
        {
          whyChoose.map((reason, index) => (
            <article class="why-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{reason}</h3>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Recent projects and impact"
        title="Supply and delivery work organized for quick review."
        body="Use this section to highlight real project photos, delivery records, and approved client references."
      />
      <div class="impact-grid">
        {
          projects.slice(0, 3).map((project) => (
            <article class="placeholder-card">
              <div class="image-placeholder">{project.title}</div>
              <div>
                <small>{project.client}</small>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
