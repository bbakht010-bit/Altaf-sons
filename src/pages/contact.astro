---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { contact, site } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Contact Altaf & Sons through official company channels for procurement, general order supplies, and humanitarian aid supply requirements."
>
  <PageHero
    eyebrow="Contact"
    title="Send a requirement or request a quotation."
    body={contact.intro}
  />

  <section class="section">
    <div class="container contact-grid">
      <div>
        <SectionHeading
          eyebrow="Get in touch"
          title="Share the details needed for a clear quotation."
          body="For the fastest reply, include the product list, quantity, delivery city, and deadline."
        />

        <div class="contact-methods">
          {
            contact.methods.map((method) => (
              <a href={method.href}>
                <span>{method.label}</span>
                <strong>{method.value}</strong>
              </a>
            ))
          }
        </div>
      </div>

      <form
        class="contact-form"
        name="request"
        method="post"
        action={`mailto:${site.email}?subject=Quote%20Request%20for%20Altaf%20%26%20Sons`}
        enctype="text/plain"
      >
        <label>
          Full name
          <input type="text" name="name" placeholder="Your name" required />
        </label>
        <label>
          Organization
          <input type="text" name="organization" placeholder="Company, NGO, or department" />
        </label>
        <label>
          Email address
          <input type="email" name="email" placeholder="name@example.com" required />
        </label>
        <label>
          Phone number
          <input type="tel" name="phone" placeholder="+92 ..." />
        </label>
        <label class="full">
          Requirement
          <textarea
            name="message"
            rows="6"
            placeholder="Example: 500 hygiene kits, Lahore delivery, needed by 15 June."
            required></textarea>
        </label>
        <button class="button primary" type="submit">Send Quote Request</button>
        <p class="form-note">
          Your request opens your email app and is addressed to {site.email}. WhatsApp can be connected as soon as the
          official business number is provided.
        </p>
      </form>
    </div>
  </section>

  <section class="section muted">
    <div class="container split-grid">
      <div>
        <SectionHeading
          eyebrow="Office location"
          title="Based in Lahore, Pakistan"
          body="Add the complete office address or Google Maps link here when it is approved for public display."
        />
        <div class="domain-list">
          <span>altafandsons.com</span>
          <span>altafsons.pk</span>
          <span>altafandsons.pk</span>
        </div>
      </div>
      <div class="map-placeholder">
        <div>
          <h3>Lahore Service Base</h3>
          <p>Share the approved office address or Google Maps link when you want the public map added.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
