---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { contact, site } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Contact Altaf & Sons through official company channels for procurement, general order supplies, and humanitarian aid supply requirements."
>
  <PageHero
    eyebrow="Contact"
    title="Send a requirement or request a quotation."
    body={contact.intro}
  />

  <section class="section">
    <div class="container contact-grid">
      <div>
        <SectionHeading
          eyebrow="Get in touch"
          title="Share the details needed for a clear quotation."
          body="This form uses browser validation and official company contact details only. A live message service can be connected later using private dashboard settings."
        />

        <div class="contact-methods">
          {
            contact.methods.map((method) => (
              <a href={method.href}>
                <span>{method.label}</span>
                <strong>{method.value}</strong>
              </a>
            ))
          }
        </div>
      </div>

      <form class="contact-form" name="request" method="post" action={`mailto:${site.email}`}>
        <label>
          Full name
          <input type="text" name="name" placeholder="Your name" required />
        </label>
        <label>
          Organization
          <input type="text" name="organization" placeholder="Company, NGO, or department" />
        </label>
        <label>
          Email address
          <input type="email" name="email" placeholder="name@example.com" required />
        </label>
        <label>
          Phone number
          <input type="tel" name="phone" placeholder="+92 ..." />
        </label>
        <label class="full">
          Requirement
          <textarea
            name="message"
            rows="6"
            placeholder="Tell us about the products, services, delivery location, and timeline."
            required></textarea>
        </label>
        <button class="button primary" type="submit">Send Inquiry</button>
        <p class="form-note">
          Privacy note: no individual personal phone numbers or private credentials are published on this website.
        </p>
      </form>
    </div>
  </section>

  <section class="section muted">
    <div class="container split-grid">
      <div>
        <SectionHeading
          eyebrow="Office address"
          title="Lahore, Pakistan"
          body={site.address}
        />
        <div class="domain-list">
          <span>altafandsons.com</span>
          <span>altafsons.pk</span>
          <span>altafandsons.pk</span>
        </div>
      </div>
      <div class="map-placeholder">
        <div>
          <h3>Google Map Embed Pending</h3>
          <p>Provide the complete office address or Google Maps link to embed the final map here.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
