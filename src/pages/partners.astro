---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { partners } from "../data/site";
---

<BaseLayout
  title="Partners"
  description="View Altaf & Sons partner and client categories including United Nations agencies, NDMA, Pakistan Army, humanitarian organizations, and government departments."
>
  <PageHero
    eyebrow="Partners and clients"
    title="Trusted by formal procurement and humanitarian environments."
    body="Altaf & Sons supports procurement environments connected with UN agencies, NDMA, Pakistan Army, humanitarian organizations, government departments, and institutional clients."
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Esteemed partners"
        title="Organizations and sectors we support."
        body="A clear partner and client display for humanitarian, disaster management, government, and institutional procurement credibility."
      />
      <div class="logo-grid">
        {
          partners.map((partner) => (
            <article class={`logo-card${partner.logoSrc ? " with-logo" : ""}`}>
              {partner.logoSrc ? <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} /> : <span class="logo-mark">{partner.shortName}</span>}
              <h3>{partner.name}</h3>
              <small>{partner.type}</small>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="container statement-card">
      <p class="eyebrow">Trust and documentation</p>
      <h2>Built for formal procurement requirements.</h2>
      <p>
        The company can support client review with supplier registration documents, project references, quotations,
        and delivery coordination details where required.
      </p>
    </div>
  </section>

  <CTA />
</BaseLayout>
