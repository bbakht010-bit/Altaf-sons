---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { otherPartners, unPartners } from "../data/site";
---

<BaseLayout
  title="Partners"
  description="View Altaf & Sons partner and client categories including United Nations agencies, NDMA, Pakistan Army, humanitarian organizations, and government departments."
>
  <PageHero
    eyebrow="Partners and clients"
    title="Partner logos grouped for quick credibility."
    body="UN-affiliated agencies on one side. Humanitarian, government, and institutional partners on the other."
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Esteemed partners"
        title="Simple, visual, and easy to scan."
        body="Short keyword tags keep the page clean while the logos build trust."
      />
      <div class="partner-groups">
        <section class="partner-group-card">
          <p class="eyebrow">UN-affiliated</p>
          <div class="mini-logo-grid">
            {
              unPartners.map((partner) => (
                <article class="logo-card with-logo compact-logo-card">
                  <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} />
                  <h3>{partner.name}</h3>
                  <div class="tag-row">{partner.keywords.map((keyword) => <span>{keyword}</span>)}</div>
                </article>
              ))
            }
          </div>
        </section>
        <section class="partner-group-card">
          <p class="eyebrow">Humanitarian / government</p>
          <div class="mini-logo-grid">
            {
              otherPartners.map((partner) => (
                <article class={`logo-card compact-logo-card${partner.logoSrc ? " with-logo" : ""}`}>
                  {partner.logoSrc ? <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} /> : <span class="logo-mark">{partner.shortName}</span>}
                  <h3>{partner.name}</h3>
                  <div class="tag-row">{partner.keywords.map((keyword) => <span>{keyword}</span>)}</div>
                </article>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="container statement-card">
      <p class="eyebrow">Trust and documentation</p>
      <h2>Built for formal procurement requirements.</h2>
      <div class="keyword-strip center">
        <span>Supplier documents</span>
        <span>Project references</span>
        <span>Quotations</span>
        <span>Delivery coordination</span>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
