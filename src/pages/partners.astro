---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { partners } from "../data/site";
---

<BaseLayout
  title="Partners"
  description="View Altaf & Sons partner and client categories including United Nations agencies, NDMA, Pakistan Army, humanitarian organizations, and government departments."
>
  <PageHero
    eyebrow="Partners and clients"
    title="Partner logos in a clean sequence."
    body="UN-affiliated agencies appear first, followed by humanitarian, disaster management, government, and institutional partners."
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Esteemed partners"
        title="Simple, visual, and easy to scan."
        body="Short keyword tags keep the page clean while the logos build trust."
      />
      <div class="logo-grid partner-sequence">
        {
          partners.map((partner) => (
            <article class={`logo-card compact-logo-card${partner.logoSrc ? " with-logo" : ""}`}>
              {partner.logoSrc ? <img class="partner-logo" src={partner.logoSrc} alt={`${partner.name} logo`} /> : <span class="logo-mark">{partner.shortName}</span>}
              <h3>{partner.name}</h3>
              <div class="tag-row">{partner.keywords.map((keyword) => <span>{keyword}</span>)}</div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="container statement-card">
      <p class="eyebrow">Trust and documentation</p>
      <h2>Built for formal procurement requirements.</h2>
      <div class="keyword-strip center">
        <span>Supplier documents</span>
        <span>Project references</span>
        <span>Quotations</span>
        <span>Delivery coordination</span>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
