---
import { site } from "../data/site";

const currentPath = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? currentPath === "/" : currentPath.startsWith(href));
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand-mark" aria-hidden="true">A&S</span>
      <span>
        <strong>{site.name}</strong>
        <small>Procurement & aid supplies</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {
        site.nav.map((item) => (
          <a class={isActive(item.href) ? "active" : ""} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a class="header-cta" href="/contact/">Request Quote</a>

    <details class="mobile-menu">
      <summary aria-label="Open navigation menu">Menu</summary>
      <nav aria-label="Mobile navigation">
        {
          site.nav.map((item) => (
            <a class={isActive(item.href) ? "active" : ""} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
